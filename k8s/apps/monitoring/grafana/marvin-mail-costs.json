{
  "annotations": { "list": [] },
  "description": "Marvin Mail — per-account LLM spend, spam vs sort efficacy, and queue depth",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Spend",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.5 }
            ]
          },
          "unit": "currencyUSD",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Estimated spend — selected range (all accounts)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "sum(increase(marvin_mail_last_run_llm_input_tokens[$__range])) * 3 / 1000000 + sum(increase(marvin_mail_last_run_llm_output_tokens[$__range])) * 15 / 1000000",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 4,
          "unit": "currencyUSD",
          "mappings": [],
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Estimated cost per run — by account",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "marvin_mail_last_run_llm_input_tokens * 3 / 1000000 + marvin_mail_last_run_llm_output_tokens * 15 / 1000000",
          "legendFormat": "{{account}} / {{run_type}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
