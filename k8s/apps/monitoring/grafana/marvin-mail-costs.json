      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Heuristic catch rate — fraction of spam caught without LLM",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "(marvin_mail_last_run_spam_check_caught + marvin_mail_last_run_spam_check_suspicious) / clamp_min(marvin_mail_last_run_spam_check_caught + marvin_mail_last_run_spam_check_suspicious + marvin_mail_last_run_by_label{label=\"Spam\"}, 1)",
          "legendFormat": "{{account}} heuristic catch rate",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
