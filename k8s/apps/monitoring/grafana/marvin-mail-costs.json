          "legendFormat": "{{account}} heuristic (likely_scam)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "marvin_mail_last_run_spam_check_suspicious",
          "legendFormat": "{{account}} heuristic (suspicious)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "marvin_mail_last_run_by_label{label=\"Spam\"}",
          "legendFormat": "{{account}} LLM → Spam",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "mappings": [],
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
