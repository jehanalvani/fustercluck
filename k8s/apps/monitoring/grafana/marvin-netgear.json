    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 }, "id": 20, "title": "WAN Throughput", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "description": "Real-time WAN throughput derived from 5-min traffic meter samples. Midnight resets are clamped to 0. Zoom in to 1–6h for best resolution.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "lineInterpolation": "linear",
            "showPoints": "never",
            "drawStyle": "line",
            "gradientMode": "none"
          },
          "color": { "mode": "palette-classic" },
          "unit": "Bps",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Upload" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "Download" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 11 }, "id": 21,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "clamp_min(deriv(netgear_traffic_today_upload_bytes[10m]), 0)",
          "legendFormat": "Upload",
          "instant": false
        },
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "clamp_min(deriv(netgear_traffic_today_download_bytes[10m]), 0)",
          "legendFormat": "Download",
          "instant": false
        }
      ],
      "title": "WAN Throughput (bytes/sec)", "type": "timeseries"
    },

