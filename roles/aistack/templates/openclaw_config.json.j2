{
  "models": {
    "providers": {
      "litellm": {
        "baseUrl": "http://127.0.0.1:{{ litellm_shim_port }}",
        "api": "openai-completions",
        "models": [
          {
            "id": "local",
            "name": "Ollama qwen2.5:7b (local)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 2048
          },
          {
            "id": "claude",
            "name": "Claude Sonnet 4.6 (fallback)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "litellm/local",
        "fallback": "litellm/claude"
      },
      "llm": {
        "idleTimeoutSeconds": 0
      },
      "sandbox": {
        "mode": "all"
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "provider": "searxng"
      }
    }
  },
  "channels": {
    "bluebubbles": {
      "serverUrl": "{{ bluebubbles_server_url }}",
      "password": "{{ bluebubbles_password }}",
      "webhookPath": "/bluebubbles-webhook",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist"
    }
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "executablePath": "/usr/bin/google-chrome-stable",
    "defaultProfile": "openclaw"
  },
  "plugins": {
    "memory-qdrant": {
      "enabled": true,
      "qdrantUrl": "http://10.0.1.203:6333",
      "autoCapture": true,
      "allowPIICapture": false,
      "autoRecall": true,
      "persistToDisk": true,
      "storagePath": "/home/openclaw/.openclaw/memory/"
    }
  },
  "gateway": {
    "mode": "local",
    "port": {{ openclaw_gateway_port }},
    "trustedProxies": ["127.0.0.1"],
    "controlUi": {
      "allowedOrigins": ["https://openclaw.lan"]
    }
  }
}
