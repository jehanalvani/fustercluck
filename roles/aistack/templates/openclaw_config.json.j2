{
  "models": {
    "providers": {
      "litellm": {
        "baseUrl": "http://127.0.0.1:{{ litellm_shim_port }}",
        "api": "openai-completions",
        "models": [
          {
            "id": "local",
            "name": "Ollama {{ litellm_local_model | replace('ollama/', '') }} (local)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 2048
          },
          {
            "id": "claude",
            "name": "Claude Sonnet 4.6 (fallback)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "litellm/local"
      },
      "llm": {
        "idleTimeoutSeconds": 0
      },
      "sandbox": {
        "mode": "off"
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "web": {
      "search": {
        "provider": "searxng"
      }
    }
  },
  "channels": {
    "bluebubbles": {
      "enabled": true,
      "serverUrl": "{{ bluebubbles_server_url }}",
      "password": "{{ bluebubbles_password }}",
      "webhookPath": "/bluebubbles-webhook",
      "dmPolicy": "open",
      "groupPolicy": "allowlist"
    }
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "executablePath": "/usr/bin/google-chrome-stable",
    "defaultProfile": "openclaw"
  },
  "gateway": {
    "mode": "local",
    "port": {{ openclaw_gateway_port }},
    "trustedProxies": ["127.0.0.1"],
    "controlUi": {
      "allowedOrigins": ["https://openclaw.lan"]
    }
  }
}
