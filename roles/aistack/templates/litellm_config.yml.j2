model_list:
  # Local model — runs on 20-size GPU, data never leaves the house
  - model_name: local
    litellm_params:
      # ollama_chat uses /api/chat with native tool support; ollama/ (/api/generate) embeds tool
      # schemas as text which causes the model to output JSON instead of plain text replies.
      model: ollama_chat/{{ litellm_local_model | replace('ollama/', '') }}
      api_base: http://ollama:{{ ollama_port }}
      # GTX 1060 6 GB: 4096 default is too small (system prompt ~8.8k tokens → full truncation).
      # 8192 requires ~1 GB KV cache vs 512 MB at 4096 — fits with ~260 MB free.
      # num_keep protects the system prompt from context-window eviction.
      num_ctx: 8192
      num_keep: 7000

  # External fallback — explicit escalation only, requires conscious choice by OpenClaw/user
  - model_name: claude
    litellm_params:
      model: {{ litellm_fallback_model }}
      api_key: os.environ/ANTHROPIC_API_KEY

litellm_settings:
  # Drop unsupported params rather than erroring (Ollama doesn't support all OpenAI params)
  drop_params: True
  # Log all requests locally so we always know what went where
  success_callback: []
  failure_callback: []

general_settings:
  master_key: {{ litellm_master_key }}
  store_model_in_db: False
  disable_spend_logs: True
  disable_reset_budget: True
